import re
import random
import string
import hashlib
import sqlite3

# 🔌 Connect DB
conn = sqlite3.connect("passwords.db")
cur = conn.cursor()

# 🧱 Create table
cur.execute("""
CREATE TABLE IF NOT EXISTS passwords (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    hash TEXT
)
""")
conn.commit()

# 🔐 Hash function
def hash_password(password):
    return hashlib.sha256(password.encode()).hexdigest()

# 💪 Strength checker
def check_password_strength(password):
    score = 0
    feedback = []

    if len(password) > 10:
        score += 2
    elif len(password) >= 6:
        score += 1
    else:
        feedback.append("Password too short")

    if re.search(r"[A-Z]", password):
        score += 1
    else:
        feedback.append("Add uppercase letter")

    if re.search(r"[a-z]", password):
        score += 1
    else:
        feedback.append("Add lowercase letter")

    if re.search(r"[0-9]", password):
        score += 1
    else:
        feedback.append("Add number")

    if re.search(r"[!@#$%^&*]", password):
        score += 1
    else:
        feedback.append("Add special character")

    if score <= 2:
        strength = "Weak"
    elif score <= 4:
        strength = "Medium"
    else:
        strength = "Strong"

    return strength, feedback

# 🔁 Check reuse from DB
def is_reused(password):
    hashed = hash_password(password)
    cur.execute("SELECT * FROM passwords WHERE hash=?", (hashed,))
    return cur.fetchone() is not None

# 💾 Store password in DB
def store_password(password):
    hashed = hash_password(password)
    cur.execute("INSERT INTO passwords (hash) VALUES (?)", (hashed,))
    conn.commit()

# 🔐 Suggest strong password
def generate_strong_password():
    chars = string.ascii_letters + string.digits + "!@#$%^&*"
    return ''.join(random.choice(chars) for _ in range(12))

# 🚀 MAIN
password = input("Enter password: ")

# Check reuse
if is_reused(password):
    print("❌ Password already used! Try a new one.")
else:
    strength, feedback = check_password_strength(password)

    print("\nStrength:", strength)

    if feedback:
        print("Suggestions:")
        for f in feedback:
            print("-", f)

    if strength != "Strong":
        print("\nSuggested Password:", generate_strong_password())

    if strength == "Strong":
        store_password(password)
        print("✅ Password stored securely in database!")

# 🔒 Close DB
conn.close()
